---
//@ts-nocheck
const { pathname } = Astro.url;

const navLinks = [
  { title: "Home", path: "/" },
  { title: "People", path: "/people/" },
  { title: "Events", path: "/events/" },
  //   { title: "Example", path: "/example" },
];
---

<header>
  <nav>
    <ul>
      {
        navLinks.map((link) => {
          return (
            <li>
              <a href={link.path} class={pathname === link.path && "active"}>
                {link.title}
              </a>
            </li>
          );
        })
      }
    </ul>
  </nav>
</header>

