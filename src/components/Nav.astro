<style>
  ul {
    display: flex;
  }
  a {
    font-size: 5rem;
    -webkit-text-stroke-width: 1.5px;
    -webkit-text-stroke-color: purple;
    color: white;
  }
  .active {
    color: purple;
  }
</style>
